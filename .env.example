# Neon pooled connection string (호스트에 -pooler 포함 필수)
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require

# cron 라우트 인증 (아무 랜덤 문자열. Vercel이 Authorization: Bearer 헤더로 자동 전송)
CRON_SECRET=

# AI 브리핑 (Groq, https://console.groq.com — 무료 키)
GROQ_API_KEY=
# 선택: 미설정 시 llama-3.3-70b-versatile
GROQ_MODEL=
